function index_fake () {
	$('#payTitle span, #paySub span, #payImg img, #quickMenu .quickSection .quickLine,  #quickMenu .quickSection .quickMenuText').addClass('no_transition');
	
	if($scrollPos > 0){
		$('#mainBar.mini #mainLogo').addClass('no_opacity');
		
	}
	
	$('.trustpilot-container').removeClass('show');
	
	setTimeout(function(){
		$('#quickMenu').removeClass('show');
		$('#pay, #videoAvailable ').removeClass('show');	
	},800);
}

function index_unfake () {
	
	
	$('#payTitle span, #paySub span, #payImg img, #quickMenu .quickSection .quickLine,  #quickMenu .quickSection .quickMenuText').removeClass('no_transition');
	$('#videoAvailable, .trustpilot-container').addClass('show');	
	scrollLayer.update();
} 


