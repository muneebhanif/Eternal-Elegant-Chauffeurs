function toggle_cinema(){
	
	$('#cinema').trigger('mouseleave');
	
	if(!$('html').hasClass('cinema-mode')) {
	
	
	if(typeof scrollLayer !== "undefined"){scrollLayer.stop();};
	if(typeof itemLayer !== "undefined"){itemLayer.stop();};
	if(typeof sectionLayer !== "undefined"){sectionLayer.stop()};
	
	$borderVisibility = $('#mainBorders').hasClass('show');
	$barState = document.getElementById('mainBar').className.split(/\s+/);
	
	
	$('#menuController').removeClass('show');
	
	$('html').addClass('cinema-mode')
	
	$('.c-scrollbar').hide();
	
	$('#mainBar').addClass('mini');
	
	
	$('article').addClass('has_transition_1000').addClass('no_opacity');	
	$('#mainBorders, #callUs').removeClass('show');
	
	setTimeout(function(){
		$('#cinema').addClass('on');
		
		if(current == "index" && $scrollPos == 0){
			$('#payTitle span, #paySub span, #payImg img, #quickMenu .quickSection .quickLine,  #quickMenu .quickSection .quickMenuText').addClass('no_transition');
			$('#quickMenu').removeClass('show');
			$('#pay').removeClass('show');
		}
		
		if(current == "macro" && controller != 'fleet'){
			macro_fake();
		}
		
		if(current == "section" && $scrollPos == 0){
			$('#sectionPay').removeClass('show');
		}
		
	},450);
	
	} else {
		if(typeof scrollLayer !== "undefined"){scrollLayer.start();};
		if(typeof itemLayer !== "undefined"){itemLayer.start();};
		if(typeof sectionLayer !== "undefined"){sectionLayer.start()};
		
		$('#menuController').addClass('show');
		
		$('html').removeClass('cinema-mode')
		
		$('.c-scrollbar').show();
		
		if($borderVisibility){$('#mainBorders').addClass('show')}
		
		
		
		if(popEnabled){
			$('article').removeClass('no_opacity');
			
			$('#mainBar').attr('class','');
			
			$barState.forEach(function(e,i){
				$('#mainBar').addClass(e);
			})
			
			if(current == "index" && $scrollPos == 0){

				$('#payTitle span, #paySub span, #payImg img, #quickMenu .quickSection .quickLine,  #quickMenu .quickSection .quickMenuText').removeClass('no_transition');

				scrollLayer.update();
			}
			
			if(current == "macro" && controller != 'fleet'){
				macro_unfake();
			}
			
			if(current == "section" && $scrollPos == 0){
				$('#sectionPay').addClass('show');
			}
		} else {
			$('#mainBar').removeClass('mini')
			
			if(current == "macro") {
				$('#mainBar').addClass('small')
			}
		}
		
		
		
		$('#callUs').addClass('show');
		
		
		$('#cinema').removeClass('on');
		
	}
}














function set_lang(e) {
    e.preventDefault();
    current_url = window.location.href;
    if (current_url.indexOf("/" + lang + "/") == -1) {
        window.location = "/" + $(this).attr("rel") + "/home"
    } else {
        new_url = current_url.replace("/" + lang + "/", "/" + $(this).attr("rel") + "/");
        window.location = new_url
    }
}


