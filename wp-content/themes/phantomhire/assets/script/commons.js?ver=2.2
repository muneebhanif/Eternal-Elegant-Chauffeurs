		window.onpopstate = function(event) {
			clearTimeout(popTimeout);
			target = event.state.current;
			targetController = event.state.controller;
			targetUrl = event.state.url;
			managePopState(event); 	
		}
		
		function managePopState (event) {
						
			if(popEnabled){
			popEnabled = false;
			clearTimeout(navigateTimeout);
			
			if($('html').hasClass('cinema-mode')) {
				
				toggle_cinema();
			}
	
			now = current;
			
					
			if(targetController == "index"){ // se stiamo tornando all'inizio
				
				if(current == "detail"){
					window[controller+'_detail_remove'](targetUrl,false);
				} else {
					window[controller+'_remove'](targetUrl,false);
				}
				
				
			}
			
			if(target == "macro"){
				
				if(current == "detail" && targetController == controller){
					window[controller+'_to_macro'](targetUrl,false);
				} else if(current == "detail") {
					window[controller+'_detail_remove'](targetUrl,false);
				} else {
					window[controller+'_remove'](targetUrl,false);
				}
					
			}
			
			if(target == "detail"){
				
				if(current == "macro" && targetController == controller){
					window[controller+'_to_detail'](targetUrl,false);
				} else if(current == "macro" && targetController == controller){
					window[controller+'_to_detail'](targetUrl,false);
				} else if(current == "detail" && target == "detail" && controller == "packages" && targetController == "packages"){
					reloadPackageDetail(targetUrl, false);
				} else if((current == "detail" && target == "detail" && controller == "fleet" && targetController == "fleet") || (current == "detail" && target == "detail" && controller == "magazine" && targetController == "magazine") ){
					window[controller+'_detail_to_detail'](targetUrl,false);
				} else if(current == "detail"){
					window[controller+'_detail_remove'](targetUrl,false);
				} else {
					window[controller+'_remove'](targetUrl,false);
				}
				
			}
			
			if(target == "section"){
				
				if(current == "detail"){
					window[controller+'_detail_remove'](targetUrl,false);
				} else {
					window[controller+'_remove'](targetUrl,false);
				}
				
			}

			
			current = target;
			controller = targetController;

			} else {
				clearTimeout(popTimeout);
				popTimeout = setTimeout(function(){
						managePopState (event);
				},500)
			}
			
		}
		
		
		
		if(firstRun && $('#main').attr('data-controller') == "index"){
			 var stateObj = { controller: $('#main').attr('data-controller'), current:$('#main').attr('data-current'), url:"/"};
			 history.replaceState(stateObj, "", window.location.href);
		} else if(firstRun) {
			 var stateObj = { controller: $('#main').attr('data-controller'), current:$('#main').attr('data-current'), url:window.location.href};
			 history.replaceState(stateObj, "", window.location.href);
		}

		
