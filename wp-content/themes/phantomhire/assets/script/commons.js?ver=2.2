function init_slider(scope,source){	
	var $sliderCount = $('.slide_container',scope).length;
	

	var $sliderActive = $('.slide_container.active',scope).index();
	
	$('.slider_arrows > div',scope).unbind('click');
	
	//$('.controller .handle',scope).css('transform','scale('+(1/$sliderCount)*($sliderActive+1)+',1)');

	
	
	$('.slider_arrows .button_right',scope).bind('click',function(e){
		if($('.slide_container.active',scope).index() < $sliderCount-1){
			$sliderActive = $('.slide_container.active',scope).index() + 1;
		} else {
			$sliderActive = 0;
		}
		
		run_slider(scope,$sliderActive,$sliderCount,'>',source);
	});
	
	$('.slider_arrows .button_left',scope).bind('click',function(e){
		if($('.slide_container.active',scope).index() == 0){
			$sliderActive = $sliderCount-1;
		} else {
			$sliderActive = $('.slide_container.active',scope).index() - 1;
		}
		run_slider(scope,$sliderActive,$sliderCount,'<',source);
	});
	
}


var galleryIndex = 0;

function run_slider (scope,$sliderActive,$sliderCount,$direction,$source){
	$restartIndex = scope.index('.gallery_container');	
	
	galleryIndex++;
	$('.button_right, .button_left',scope).css('pointer-events','none');
	
	if($('.slide_container:eq('+($sliderActive)+') img',scope)[0].hasAttribute("gallery-src")){
		$('.slide_container:eq('+($sliderActive)+') img',scope).attr('src',$('.slide_container:eq('+($sliderActive)+') img',scope).attr('gallery-src')).removeAttr('gallery-src');
		
		if($('.slide_container:eq('+($sliderActive)+') img',scope)[0].hasAttribute("gallery-srcset")){
					$('.slide_container:eq('+($sliderActive)+') img',scope).attr('srcset',$('.slide_container:eq('+($sliderActive)+') img',scope).attr('gallery-srcset')).removeAttr('gallery-srcset');

		}
		
		if($fullscreen){
			$('#fullscreenGallery .controllerBackground').removeClass('opaque');
		}
		
		$('.gallery_controller .controls .loading',scope).addClass('show');

		
		
		$('.slide_container:eq('+($sliderActive)+') img',scope).imagesLoaded(function(){
			
			
			$('.button_right, .button_left',scope).css('pointer-events','all');
			
			if($direction == '>'){
					if($source){
						$('.next', $source).trigger('click');
					}
				}
				
			
			
			if($direction == '<'){
				if($source){
					$('.prev', $source).trigger('click');
				}
				
			}
			
			$('.slide_container',scope).removeClass('active');
			$('.slide_container:eq('+($sliderActive)+') .slide, .slide_container:eq('+($sliderActive)+') .t_container, .slide_container:eq('+($sliderActive)+') img',scope).addClass('no_transition');
			$('.slide_container:eq('+($sliderActive)+')',scope).css('z-index',galleryIndex).removeClass('show').addClass('active');

			
			if($direction == '>'){
				$('.slide_container:eq('+($sliderActive)+') .slide',scope).removeClass('mask_right').addClass('mask_left');
				

			}
			
			if($direction == '<'){
				$('.slide_container:eq('+($sliderActive)+') .slide',scope).removeClass('mask_left').addClass('mask_right');
				

			}
			
			setTimeout(function(){
				$('.slide_container:eq('+($sliderActive)+') .slide, .slide_container:eq('+($sliderActive)+') .t_container, .slide_container:eq('+($sliderActive)+') img',scope).removeClass('no_transition');
				$('.slide_container:eq('+($sliderActive)+')',scope).addClass('show');
			},15);
			
			$('.controller .handle',scope).css('transform','scale('+(1/$sliderCount)*($sliderActive+1)+',1)');
			
			if(($sliderActive+1) <= 9){ 
				$('.caption .currentNum, .counter .currentPic',scope).text('0'+($sliderActive+1));
			} else {
				$('.caption .currentNum, .counter .currentPic',scope).text(($sliderActive+1));
			}
			
			$('.picBullets .bullet').removeClass('active');
			$('.picBullets .bullet:eq('+$sliderActive+')').addClass('active');
			
			$('.gallery_controller .controls .loading',scope).removeClass('show')
			setTimeout(function(){$('#fullscreenGallery .controllerBackground').addClass('opaque');},200);
			
		})
	} else {
		

		$('.button_right, .button_left',scope).css('pointer-events','all');
		
		if($direction == '>'){
			if($source){
				$('.next', $source).trigger('click');
			}
		}
		
	
	
	if($direction == '<'){
		if($source){
			$('.prev', $source).trigger('click');
		}
		
	}
	

	$('.slide_container',scope).removeClass('active');
	$('.slide_container:eq('+($sliderActive)+') .slide, .slide_container:eq('+($sliderActive)+') .t_container, .slide_container:eq('+($sliderActive)+') img',scope).addClass('no_transition');
	$('.slide_container:eq('+($sliderActive)+')',scope).css('z-index',galleryIndex).removeClass('show').addClass('active');

	
	if($direction == '>'){
		$('.slide_container:eq('+($sliderActive)+') .slide',scope).removeClass('mask_right').addClass('mask_left');
		

	}
	
	if($direction == '<'){
		$('.slide_container:eq('+($sliderActive)+') .slide',scope).removeClass('mask_left').addClass('mask_right');
		

	}
	
		setTimeout(function(){
			$('.slide_container:eq('+($sliderActive)+') .slide, .slide_container:eq('+($sliderActive)+') .t_container, .slide_container:eq('+($sliderActive)+') img',scope).removeClass('no_transition');
			$('.slide_container:eq('+($sliderActive)+')',scope).addClass('show');
		},15);
		
		$('.controller .handle',scope).css('transform','scale('+(1/$sliderCount)*($sliderActive+1)+',1)');
		
		if(($sliderActive+1) <= 9){ 
			$('.caption .currentNum, .counter .currentPic',scope).text('0'+($sliderActive+1));
		} else {
			$('.caption .currentNum, .counter .currentPic',scope).text(($sliderActive+1));
		}
		
		$('.picBullets .bullet').removeClass('active');
		$('.picBullets .bullet:eq('+$sliderActive+')').addClass('active');
	}
	
	
	if(scope.parent().parent().hasClass('generic')){
		$('.picTitle',scope).text($('.slide_container:eq('+($sliderActive)+') img',scope).attr('alt'))
	}
	
	
	if($('.gallery_controller',scope).hasClass('captions') && $('.captionScroller > *').length > 1){
		$('.captionScroller',scope).css('transform','translateY(-'+(20*$sliderActive)+'px');
	}
	
}

function launchFullScreenGallery() {
	launcher = $(this);
	source = $(this).parent().parent();
	
	if(controller == "gallery"){
		source = $(this);
	}
	
	
	if($('.counter',source).length != 0){
	startIndex = parseInt($('.counter',source).text());
	} else {
		startIndex = 1;
	}
	title = $(this).attr('title');
	
	if(source.attr('id') == "vehicleGallery"){
		$('#fullscreenGallery .gallery_container').attr('type','vehicle');
	} else {
		$('#fullscreenGallery .gallery_container').attr('type','default');
	}
	
	
	$('#fullscreenGallery .gallery_container .gallery_slider').empty();
	launchIntoFullscreen($('#fullscreenGallery .gallery_container')[0]);
	$fullscreen = true;
	$('#fullscreenGallery').show();
	$('.fullscreenLauncher').unbind();
	$('.fullscreenLauncher').bind('click',closeFullScreenGallery);
	$('#fullscreenGallery .controllerBackground').removeClass('opaque');
	
	setTimeout(function(){
		$('#fullscreenGallery .gallery_controller').removeClass('top_hidden');
	},500);
	

	

	$data = $('.gallery_slider',source).children().clone();
	
	
			$('#fullscreenGallery .gallery_container .gallery_slider').append($data); 
			$('#fullscreenGallery .gallery_container .gallery_slider .slide_container').removeClass('active').removeClass('show');
			$('#fullscreenGallery .gallery_container .gallery_slider .slide_container img').attr('sizes','100vw');
			$('#fullscreenGallery .gallery_controller .galleryTitle').text(title);
			$('#fullscreenGallery .gallery_controller .counter .currentPic').text('0'+(startIndex));
			$('#fullscreenGallery .gallery_controller .counter .totalPic').text('0'+ $('#fullscreenGallery .slide_container').length);
			$('#fullscreenGallery .gallery_container .slide_container:eq('+(startIndex-1)+')').addClass('active');
			init_slider($('#fullscreenGallery .gallery_container'),source);
			
			
			if($('#fullscreenGallery .gallery_container .slide_container:eq('+(startIndex-1)+') img')[0].hasAttribute("gallery-src")){
				$('#fullscreenGallery .gallery_container .slide_container:eq('+(startIndex-1)+') img').attr('src',$('#fullscreenGallery .gallery_container .slide_container:eq('+(startIndex-1)+') img').attr('gallery-src')).removeAttr('gallery-src');
			}
			
			$('#fullscreenGallery .gallery_container .slide_container:eq('+(startIndex-1)+') img').imagesLoaded(function(){
				$('#fullscreenGallery .fullscreenIcon').removeClass('show');
				
				$('#fullscreenGallery .gallery_container .slide_container:eq('+(startIndex-1)+')').addClass('show');
				$('#fullscreenGallery .fullscreenLauncher').addClass('no_opacity');
				setTimeout(function(){
				$('#fullscreenGallery .controllerBackground').addClass('opaque');
				},200);
				
				
				
				setTimeout(function(){
					$('.gallery_advice').removeClass('no_opacity')
					$('#fullscreenGallery .fullscreenLauncher').removeClass('no_opacity');
					$('#fullscreenGallery .fullscreenLauncher .fullscreenClose').show();
					$('#fullscreenGallery .fullscreenLauncher span').text('CLOSE IMMERSIVE FULLSCREEN');
					$('#fullscreenGallery .fullscreenLauncher .fullscreenIcon').hide();
				},800)
				
			})
			
		
	
}

function closeFullScreenGallery() {
	if(document.webkitFullscreenElement || document.fullscreenElement || document.msFullscreenElement){exitFullScreen()};
	$('#fullscreenGallery').hide();
	$('.fullscreenLauncher').unbind();
	$('.fullscreenLauncher').bind('click',launchFullScreenGallery);
	$('#fullscreenGallery .gallery_controller').addClass('top_hidden');
	$('#fullscreenGallery .fullscreenLauncher').removeClass('no_opacity');
	$('#fullscreenGallery .controllerBackground').removeClass('opaque');
	$('#fullscreenGallery .fullscreenLauncher span').text('LOADING IMAGE SET');
	$('#fullscreenGallery .fullscreenLauncher .fullscreenIcon').show();
	$('#fullscreenGallery .fullscreenLauncher .fullscreenClose').hide();
	$('.gallery_advice').addClass('no_opacity');
	$fullscreen = false;
}

var $fullscreen = false;

function launchIntoFullscreen(element) {
	if(element.requestFullscreen) {
	    element.requestFullscreen();
	  } else if(element.mozRequestFullScreen) {
	    element.mozRequestFullScreen();
	  } else if(element.webkitRequestFullscreen) {
	    element.webkitRequestFullscreen();
	  } else if(element.msRequestFullscreen) {
	    element.msRequestFullscreen();
	  }
	}


function exitFullScreen()
{

    if (document.exitFullscreen)
        document.exitFullscreen();
    else if (document.msExitFullscreen)
        document.msExitFullscreen();
    else if (document.mozCancelFullScreen)
        document.mozCancelFullScreen();
    else if (document.webkitExitFullscreen)
        document.webkitExitFullscreen();
}

function gallery_init(scope){	  
	is_gallery = true;
		
	if(!isHandheld){		
			
		$(document).on('webkitfullscreenchange mozfullscreenchange fullscreenchange MSFullscreenChange', function(){
			if(document.webkitFullscreenElement || document.fullscreenElement || document.msFullscreenElement){
				$('.gallery_container .gallery_slider',scope).addClass('no_transform');
				$('body').addClass('isFullscreen');
				$(window).trigger('resize');
				setTimeout(function(){
					$(window).trigger('resize');
				},100)
			} else {
				$('.gallery_container .gallery_slider',scope).removeClass('no_transform');
				$('body').removeClass('isFullscreen');
				closeFullScreenGallery();				
			}
		});
		
	} else {
		
		$(document).on('webkitfullscreenchange mozfullscreenchange fullscreenchange MSFullscreenChange', function(){
			if(document.webkitFullscreenElement || document.fullscreenElement || document.msFullscreenElement){		
				$('body').addClass('isFullscreen');
				$(window).trigger('resize');
				setTimeout(function(){
					$(window).trigger('resize');
				},100)
			} else {
				$('body').removeClass('isFullscreen');
				closeFullScreenGallery();
			}
		});
	}
	
	
			$('.gallery_close').bind('click',function(){
				$('.gallery_container .gallery_slider',scope).removeClass('no_transform');
				$('body').removeClass('isFullscreen');
				closeFullScreenGallery();				
			})
		
	
}



function initReviewSlider(){
	reviewSlider = new Glide('#reviewSlider', {
		  gap: 300,
		  type: "slider",
		  bound:true,
	      autoplay:false,
	      animationDuration:700,
	      perView:1,
	      animationTimingFunc:'cubic-bezier(0.215, 0.610, 0.355, 1.000)',
	      rewind:true
	 })
	

	if(mobileCheck){
		reviewSlider.on('build.after', function() {
			var slideHeight = $('.glide__slide--active').outerHeight();
			var glideTrack = $('.glide__track').outerHeight();
			if (slideHeight != glideTrack) {
				var newHeight = slideHeight;
				$('.glide__track').css('height', newHeight);
			}
		});

		reviewSlider.on('run', function(data) {
			
			if(data.direction == ">"){
				var slideHeight = $('.glide__slide--active').next().outerHeight();
				if($('.glide__slide--active').index() == $('.glide__slide').length - 1){
					var slideHeight = $('.glide__slide:eq(0)').outerHeight();
				}
				var glideTrack = $('.glide__track').outerHeight();
				if (slideHeight != glideTrack) {
					var newHeight = slideHeight;
					$('.glide__track').css('height', newHeight);
				}
			}
			
			if(data.direction == "<"){
				var slideHeight = $('.glide__slide--active').prev().outerHeight();
				if($('.glide__slide--active').index() == 0){
					var slideHeight = $('.glide__slide:last-child').outerHeight();
				}
				var glideTrack = $('.glide__track').outerHeight();
				if (slideHeight != glideTrack) {
					var newHeight = slideHeight;
					$('.glide__track').css('height', newHeight);
				}
			}
			
			if(data.direction == "="){
				var slideHeight = $('.glide__slide:eq('+data.steps+')').outerHeight();
				var glideTrack = $('.glide__track').outerHeight();
				if (slideHeight != glideTrack) {
					var newHeight = slideHeight;
					$('.glide__track').css('height', newHeight);
				}
			}
		})
	}
	
	reviewSlider.mount();
}


