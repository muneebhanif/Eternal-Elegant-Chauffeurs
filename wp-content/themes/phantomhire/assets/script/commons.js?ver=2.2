function getSection (href, delay, pushState) {
	var $newData = "loading";
	
	if(!!$('#promoBanner').length){
		$('body').removeClass('active');
	}

	$.get(href, function(data,success){
			 $newData = data;
			 $newTitle = $($newData).filter('title').text();
			 $newDescription = $($newData).filter('meta[name=description]').attr('content');
			 $newKeys = $($newData).filter('meta[name=keywords]').attr('content');
			 $('head title').html($newTitle);
			 $('head meta[name=description]').attr('content',$newDescription);
			 $('head meta[name=keywords]').attr('content',$newKeys);
			 gtag('event', 'page_view', {
			 page_title: $newTitle,
			 page_location: href
			 });
			
			 fbq('track', 'PageView');
			
			 
	});

		
	function data_ready(){
			if($newData != "loading"){

				 $mainContent = $($newData).filter('#main');
				 $('#main').remove();
				 $('#mainBar').after($mainContent);
				
				 
				 current =  $('#main').attr('data-current');
				 controller =  $('#main').attr('data-controller');
				 action = $('#main').attr('data-action');
					 
				 $('body').attr('id',controller).attr('class',action);
				 
				 if(pushState){
				 var stateObj = { controller: controller, current:current,url:href};
				 history.pushState(stateObj, "", href);
				 }
				 
				 
				if(loadedJsControllers.indexOf(controller) == -1){
					loadedJsControllers.push(controller);
					 $.getScript( '/wp-content/themes/phantomhire/assets/script/'+controller+'.js', function() {
					 common_ready();
					});
				} else {
					common_ready();
				}
				
			} else {
				setTimeout(data_ready,10);
			}
	}
	
	setTimeout(data_ready,delay);
	
		
}

